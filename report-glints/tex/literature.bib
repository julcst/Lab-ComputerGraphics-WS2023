@article{jakob2014,
  title = {Discrete Stochastic Microfacet Models},
  author = {Jakob, Wenzel and Hašan, Miloš and Yan, Ling-Qi and Lawrence, Jason and Ramamoorthi, Ravi and Marschner, Steve},
  date = {2014-07-27},
  journaltitle = {ACM Transactions on Graphics},
