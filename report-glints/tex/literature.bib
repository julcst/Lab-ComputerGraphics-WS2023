@article{deng2022,
  title = {Constant-{{Cost Spatio-Angular Prefiltering}} of {{Glinty Appearance Using Tensor Decomposition}}},
  author = {Deng, Hong and Liu, Yang and Wang, Beibei and Yang, Jian and Ma, Lei and Holzschuch, Nicolas and Yan, Ling-Qi},
  date = {2022-04-30},
  journaltitle = {ACM Transactions on Graphics},
  shortjournal = {ACM Trans. Graph.},
  volume = {41},
  number = {2},
