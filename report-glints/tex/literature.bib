@article{chermain2020a,
  title = {Procedural {{Physically}} Based {{BRDF}} for {{Real}}‐{{Time Rendering}} of {{Glints}}},
  author = {Chermain, X. and Sauvage, B. and Dischler, J.‐M. and Dachsbacher, C.},
  date = {2020-10},
  journaltitle = {Computer Graphics Forum},
  shortjournal = {Computer Graphics Forum},
